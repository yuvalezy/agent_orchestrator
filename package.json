{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Solo-founder chief-of-staff: multi-channel ingestion + triage orchestrator (WhatsApp / Gmail / EZY service desk). M1.1 service skeleton.",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy:sql",
    "copy:sql": "node -e \"const fs=require('fs'),p=require('path');const s='src/db/migrations',d='dist/db/migrations';fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.sql'))fs.copyFileSync(p.join(s,f),p.join(d,f));\"",
    "build:console": "npm --prefix web run build",
    "build:app": "npm --prefix app run build",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "migrate": "tsx src/db/migrate.ts",
    "db:create": "tsx scripts/create-db.ts",
    "onboard": "tsx scripts/onboard-customer.ts --",
    "reconcile:once": "tsx scripts/reconcile-once.ts",
    "knowledge:reconcile:once": "tsx scripts/knowledge-reconcile-once.ts",
    "internal:reconcile:once": "tsx scripts/internal-reconcile-once.ts",
    "task-inventory:reconcile:once": "tsx scripts/task-inventory-reconcile-once.ts",
    "customer:identity": "tsx scripts/customer-identity.ts",
    "backfill:dry": "tsx scripts/backfill-dry.ts",
    "backfill:run": "tsx scripts/backfill-run.ts",
    "backfill:recollapse": "tsx scripts/backfill-recollapse.ts",
    "backfill:style-kind": "tsx scripts/backfill-style-kind.ts",
    "feedback:check": "tsx scripts/feedback-check.ts",
    "settings:import": "tsx scripts/settings-import.ts",
    "mcp:project-brain": "tsx scripts/mcp-project-brain.ts",
    "smoke:webhook": "tsx scripts/smoke-webhook.ts --",
    "triage:sample": "tsx scripts/triage-sample.ts --",
    "contract:ezy": "tsx scripts/contract-ezy-tasks.ts",
    "gmail:oauth": "tsx scripts/gmail-oauth.ts --",
    "calendar:oauth": "tsx scripts/calendar-oauth.ts --",
    "typecheck": "tsc --noEmit",
    "typecheck:console": "npm --prefix web run typecheck",
    "test:containers": "RUN_CONTAINERS=true node --import tsx --test src/adapters/console/console-mutations.container.test.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "lint:boundary": "node scripts/check-boundary.mjs",
    "ci": "bash ci.sh"
  },
  "dependencies": {
    "@hebcal/core": "^6.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "date-holidays": "^3.32.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.0.0",
    "luxon": "^3.7.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^3.7",
    "eslint-plugin-import": "^2.31",
    "testcontainers": "^12.0.4",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  },
  "engines": {
    "node": ">=20"
  }
}
