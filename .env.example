NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Database — DATABASE_URL wins when present, otherwise the discrete PG* vars.
# Points at the shared ops-dev `ezy-postgres`, host-published on 42016. Under
# docker `network_mode: host` (ADR-11/BF1) the container uses these SAME
# localhost values — do not switch to ezy-postgres:5432.
PGHOST=localhost
PGPORT=42016
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=agent_orchestrator
# DATABASE_URL=postgres://postgres:postgres@localhost:42016/agent_orchestrator

# ── M1.2: outbound-edge base URLs (NON-secret) ──
# Host-mode defaults; under docker network_mode:host the container uses the same
# localhost values. WA runs on its own compose, portal is a host process.
EZY_PORTAL_BASE_URL=http://localhost:5040
WHATSAPP_MANAGER_BASE_URL=http://localhost:3000

# ── M1.2: Telegram forum ids (NON-secret; the bot TOKEN is a credential below) ──
# Supergroup chat id — the -100XXXXXXXXXX number (from getUpdates / @RawDataBot).
TELEGRAM_SUPERGROUP_CHAT_ID=
# message_thread_id of the pinned "Admin" topic (optional; blank = General topic).
TELEGRAM_ADMIN_TOPIC_ID=

# ── M1.2: SECRETS — resolved via src/config/credentials.ts (env now; M1.4 sealed
#          store later). NEVER add these to the zod schema or channel_instances.config.
# EZY Portal tenant API key (scoped ten_ key). Ref: EZY_PORTAL_API_KEY.
EZY_PORTAL_API_KEY=
# whatsapp_manager read key (x-api-key). Ref: WHATSAPP_MANAGER_API_KEY.
WHATSAPP_MANAGER_API_KEY=
# Telegram bot token from BotFather (12345:AA...). Ref: TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=

# ── M1.3: WhatsApp ingestion ──
# SECRET — shared HMAC secret; MUST match whatsapp_manager's WEBHOOK_SECRET so the
# webhook signature (X-Signature: sha256=…) verifies. Resolved via resolveCredential.
WEBHOOK_SECRET=
# Pull-reconciliation tuning (NON-secret; defaults shown). The test env may set the
# interval low (e.g. 15000) for deterministic drills.
# WHATSAPP_RECONCILE_INTERVAL_MS=900000
# WHATSAPP_RECONCILE_LOOKBACK_MS=5000
# WHATSAPP_RECONCILE_MAX_PAGES=200

# ── M1.4: LLM gateway ──
# SECRETS (read directly from process.env, NOT the zod schema):
#   CREDENTIALS_ENCRYPTION_KEY — master key (KEK) for the sealed credentials store.
#     Set any strong string; enables `POST /admin/credentials` + encrypted-at-rest keys.
#     If unset, the store is disabled and keys fall back to the env vars below.
CREDENTIALS_ENCRYPTION_KEY=
#   ADMIN_API_KEY — guards the /admin/* endpoints (x-admin-key header). If unset,
#     the admin router is NOT mounted (fail-closed).
ADMIN_API_KEY=
# Provider API keys (SECRETS). Set here as the env fallback, OR store them sealed via
# `POST /admin/credentials {"name":"ANTHROPIC_API_KEY","value":"..."}`. The gate needs
# Anthropic + one of OpenAI/DeepSeek (for the failover + golden-schema drills).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# LLM routing config (NON-secret; defaults shown).
# LLM_DEFAULT_PROVIDER=anthropic
# LLM_FALLBACK_CHAIN=openai,deepseek
# LLM_DAILY_COST_CAP_USD=10
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Per-(provider,role) model overrides (NON-secret; optional). Defaults: anthropic
# triage/draft=claude-sonnet-5 classify=claude-haiku-4-5; openai triage/draft=gpt-4.1
# classify=gpt-4.1-mini; deepseek all=deepseek-chat. Override any as needed:
# LLM_MODEL_ANTHROPIC_TRIAGE=claude-sonnet-5
# LLM_MODEL_OPENAI_TRIAGE=gpt-4.1
# LLM_MODEL_DEEPSEEK_TRIAGE=deepseek-chat

# Reasoning EFFORT per provider (NON-secret; optional; low|medium|high|xhigh|max).
# Lower = less thinking = cheaper/faster — set 'low' for testing. Applies to the
# triage/draft roles only (NOT classify: its default model claude-haiku-4-5 has no
# adaptive thinking). Anthropic → output_config.effort (sonnet-5/opus adaptive
# thinking). OpenAI → reasoning_effort — set ONLY if you switch to a reasoning
# model (o-series/gpt-5); gpt-4.1 is NOT a reasoning model and would reject it.
# DeepSeek has no effort param — pick the model instead (deepseek-chat vs
# deepseek-reasoner) via LLM_MODEL_DEEPSEEK_*.
LLM_ANTHROPIC_EFFORT=low
# LLM_OPENAI_EFFORT=low
# Fine-grained override per (provider,role) — e.g. force effort on classify:
# LLM_EFFORT_ANTHROPIC_TRIAGE=low
