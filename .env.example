# ─────────────────────────────────────────────────────────────────────────────
# Agent Orchestrator — .env  (GITIGNORED — never commit real values)
#
# As of the settings/connectors migration, most configuration lives in the DATABASE,
# not here:
#   • Feature flags (the *_ENABLED toggles)  → app_settings table, managed in the
#     console  Settings  tab  (DB-authoritative; values here are IGNORED).
#   • Secrets & OAuth (LLM keys, portal/WhatsApp/Telegram keys, webhook secret, the
#     Gmail/Calendar account tokens)          → encrypted `credentials` store, managed
#     in the console  Connectors  tab.
#
# This file now holds ONLY: bootstrap (DB + master key + port), the console/OAuth
# bootstrap secrets, and non-secret runtime knobs (base URLs, ids, LLM routing).
# ─────────────────────────────────────────────────────────────────────────────

# ── Bootstrap (process needs these before the DB/credential store is available) ──
NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Database — DATABASE_URL wins when present, else the discrete PG* vars. Points at the
# dedicated pgvector Postgres `ao-postgres` (docker-compose.db.yml) on :55432.
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=agent_orchestrator
# DATABASE_URL=postgres://postgres:postgres@localhost:55432/agent_orchestrator

# Master key (KEK) for the encrypted credentials store. Any strong string; scrypt-derived.
# REQUIRED for the Connectors tab to store secrets/OAuth. Read directly from process.env
# (never the DB — chicken/egg). If unset, the store is disabled and secrets fall back to env.
CREDENTIALS_ENCRYPTION_KEY=

# ── Console + OAuth bootstrap (not managed by the console itself) ──
# Console login (bcrypt hash) + session/CSRF signing secret. Tailscale-only surface.
CONSOLE_PASSWORD_HASH=
CONSOLE_SESSION_SECRET=
# Public origin the console is reached at — used to build the Google OAuth redirect URI
# (<CONSOLE_PUBLIC_URL>/console/api/connectors/oauth/callback must be registered in GCP).
CONSOLE_PUBLIC_URL=http://localhost:3100
# Guards /admin/* (x-admin-key). If unset, the admin router is NOT mounted (fail-closed).
ADMIN_API_KEY=
# Google "Web application" OAuth client used by the Connectors OAuth flow — JSON
# {"web":{"client_id":"…","client_secret":"…"}} (or a flat {client_id,client_secret}).
GOOGLE_OAUTH_CLIENT=
# whatsapp_manager outbound write key (matches its OUTBOUND_API_KEY, scoped to POST /outbound/send).
WHATSAPP_MANAGER_WRITE_KEY=

# ── Non-secret runtime config (base URLs, ids, knobs — env for now; pass-2 → DB) ──
EZY_PORTAL_BASE_URL=https://account.ezyts.com
EZY_PORTAL_CORE_BASE_URL=https://account.ezyts.com
WHATSAPP_MANAGER_BASE_URL=http://localhost:3000
# Telegram forum ids (the bot TOKEN is a Connectors secret, not here).
TELEGRAM_SUPERGROUP_CHAT_ID=
TELEGRAM_ADMIN_TOPIC_ID=

# LLM routing (non-secret; the provider API keys live in the Connectors store).
LLM_DEFAULT_PROVIDER=deepseek
LLM_FALLBACK_CHAIN=anthropic,openai
LLM_ANTHROPIC_EFFORT=low
LLM_OPENAI_EFFORT=low
# LLM_DAILY_COST_CAP_USD=10

# Tuning knobs (non-secret; defaults shown — override as needed).
STYLE_LANE_MAX=12
# BACKFILL_COLLAPSE_MAX_DISTANCE=0.3
# BACKFILL_JUDGE_VOTES=3
# EMAIL_RECONCILE_INTERVAL_MS=60000
# SERVICE_DESK_RECONCILE_INTERVAL_MS=60000
# CALENDAR_LOOKAHEAD_DAYS=7
# CALENDAR_MAX_EVENTS=5
# CALENDAR_TZ=America/Panama

# Onboarding test refs (non-secret UUIDs used by npm run onboard in tests).
TEST_BP_REF=
TEST_PROJECT_REF=

# ─────────────────────────────────────────────────────────────────────────────
# NOT here anymore (managed in the console):
#   Feature flags → Settings tab:  OUTBOUND_ENABLED, OUTBOUND_EMAIL_ENABLED,
#     KNOWLEDGE_{RETRIEVAL,DRAFT,SYNC,INTERNAL}_ENABLED, DRAFT_REVISE_ENABLED,
#     STYLE_LANE_ENABLED, QUERY_ENGINE_ENABLED, SLASH_COMMANDS_ENABLED,
#     BACKFILL{,_WA,_STARRED}_ENABLED, LIVE_DEDUP_FINGERPRINT_ENABLED,
#     DAILY_BRIEFING_ENABLED, WEEKLY_PATTERNS_ENABLED, ACCEPTANCE_REPORT_ENABLED,
#     FEEDBACK_LEARNING_ENABLED, RELEASE_NOTE_DRAFTS_ENABLED,
#     CROSS_CHANNEL_DEDUP_ENABLED, TASK_INVENTORY_ENABLED, CALENDAR_ENABLED.
#   Secrets → Connectors tab:  ANTHROPIC_API_KEY, OPENAI_API_KEY, DEEPSEEK_API_KEY,
#     EZY_PORTAL_API_KEY, WHATSAPP_MANAGER_API_KEY, TELEGRAM_BOT_TOKEN, WEBHOOK_SECRET,
#     and the Gmail/Calendar account OAuth tokens (per-account, add/label/disable there).
# ─────────────────────────────────────────────────────────────────────────────
