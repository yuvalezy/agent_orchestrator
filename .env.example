NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Database — DATABASE_URL wins when present, otherwise the discrete PG* vars.
# Points at the DEDICATED pgvector Postgres `ao-postgres` (docker-compose.db.yml),
# host-published on 55432 — SEPARATE from the shared ops-dev ezy-postgres (:42016)
# so the vector RAG + migrations never bounce the portal dev stack. Bring it up with
# `docker compose -f docker-compose.db.yml up -d`. Under docker network_mode:host the
# container uses these SAME localhost values.
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=agent_orchestrator
# DATABASE_URL=postgres://postgres:postgres@localhost:55432/agent_orchestrator

# ── M1.2: outbound-edge base URLs (NON-secret) ──
# Host-mode defaults; under docker network_mode:host the container uses the same
# localhost values. WA runs on its own compose, portal is a host process.
EZY_PORTAL_BASE_URL=http://localhost:5040
# M2: portal-CORE (.NET) for the generic files service (/api/files/*) — task
# attachment uploads. A DIFFERENT service than portal-business (:5040). Default shown.
# EZY_PORTAL_CORE_BASE_URL=http://localhost:3450
WHATSAPP_MANAGER_BASE_URL=http://localhost:3000

# ── M1.2: Telegram forum ids (NON-secret; the bot TOKEN is a credential below) ──
# Supergroup chat id — the -100XXXXXXXXXX number (from getUpdates / @RawDataBot).
TELEGRAM_SUPERGROUP_CHAT_ID=
# message_thread_id of the pinned "Admin" topic (optional; blank = General topic).
TELEGRAM_ADMIN_TOPIC_ID=

# ── M1.2: SECRETS — resolved via src/config/credentials.ts (env now; M1.4 sealed
#          store later). NEVER add these to the zod schema or channel_instances.config.
# EZY Portal tenant API key (scoped ten_ key). Ref: EZY_PORTAL_API_KEY.
EZY_PORTAL_API_KEY=
# whatsapp_manager read key (x-api-key). Ref: WHATSAPP_MANAGER_API_KEY.
WHATSAPP_MANAGER_API_KEY=
# Telegram bot token from BotFather (12345:AA...). Ref: TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=
# M5(d) Google Calendar READ OAuth (JSON {client_id,client_secret,refresh_token}), scope
# https://www.googleapis.com/auth/calendar.readonly. Mint per account with `npm run calendar:oauth`
# (reuses the Gmail Google client). Multi-account: set WORK and/or PERSONAL; each reads its own
# primary calendar (override with GOOGLE_CALENDAR_{WORK,PERSONAL}_ID). Legacy single-account
# GOOGLE_CALENDAR_OAUTH still works when no split cred is set. Only read when CALENDAR_ENABLED=true.
GOOGLE_CALENDAR_WORK_OAUTH=
GOOGLE_CALENDAR_PERSONAL_OAUTH=
GOOGLE_CALENDAR_OAUTH=

# ── M1.3: WhatsApp ingestion ──
# SECRET — shared HMAC secret; MUST match whatsapp_manager's WEBHOOK_SECRET so the
# webhook signature (X-Signature: sha256=…) verifies. Resolved via resolveCredential.
WEBHOOK_SECRET=
# Pull-reconciliation tuning (NON-secret; defaults shown). The test env may set the
# interval low (e.g. 15000) for deterministic drills.
# WHATSAPP_RECONCILE_INTERVAL_MS=900000
# WHATSAPP_RECONCILE_LOOKBACK_MS=5000
# WHATSAPP_RECONCILE_MAX_PAGES=200

# ── M1.6 / M1.7: ingestion poll intervals (NON-secret; defaults shown) ──
# EMAIL_RECONCILE_INTERVAL_MS=60000            # Gmail poll cadence per instance
# SERVICE_DESK_RECONCILE_INTERVAL_MS=60000     # service-desk poll cadence
# SERVICE_DESK_BOOTSTRAP_WINDOW_DAYS=7         # first-boot lookback; 0 = start from now()

# ── M1.4: LLM gateway ──
# SECRETS (read directly from process.env, NOT the zod schema):
#   CREDENTIALS_ENCRYPTION_KEY — master key (KEK) for the sealed credentials store.
#     Set any strong string; enables `POST /admin/credentials` + encrypted-at-rest keys.
#     If unset, the store is disabled and keys fall back to the env vars below.
CREDENTIALS_ENCRYPTION_KEY=
#   ADMIN_API_KEY — guards the /admin/* endpoints (x-admin-key header). If unset,
#     the admin router is NOT mounted (fail-closed).
ADMIN_API_KEY=
# Founder console (both required; the router fails closed when either is absent).
# Create a bcrypt hash, e.g. `node -e "require('bcryptjs').hash('choose-a-long-password', 12).then(console.log)"`.
CONSOLE_PASSWORD_HASH=
# At least 32 random characters, e.g. `openssl rand -base64 48`.
CONSOLE_SESSION_SECRET=
# CONSOLE_SESSION_TTL_MS=43200000
# CONSOLE_LOGIN_WINDOW_MS=900000
# CONSOLE_LOGIN_MAX_ATTEMPTS=5
# Provider API keys (SECRETS). Set here as the env fallback, OR store them sealed via
# `POST /admin/credentials {"name":"ANTHROPIC_API_KEY","value":"..."}`. The gate needs
# Anthropic + one of OpenAI/DeepSeek (for the failover + golden-schema drills).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# LLM routing config (NON-secret; defaults shown).
# LLM_DEFAULT_PROVIDER=anthropic
# LLM_FALLBACK_CHAIN=openai,deepseek
# LLM_DAILY_COST_CAP_USD=10
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Per-(provider,role) model overrides (NON-secret; optional). Defaults: anthropic
# triage/draft=claude-sonnet-5 classify=claude-haiku-4-5; openai triage/draft=gpt-4.1
# classify=gpt-4.1-mini; deepseek all=deepseek-chat. Override any as needed:
# LLM_MODEL_ANTHROPIC_TRIAGE=claude-sonnet-5
# LLM_MODEL_OPENAI_TRIAGE=gpt-4.1
# LLM_MODEL_DEEPSEEK_TRIAGE=deepseek-chat

# Reasoning EFFORT per provider (NON-secret; optional; low|medium|high|xhigh|max).
# Lower = less thinking = cheaper/faster — set 'low' for testing. Applies to the
# triage/draft roles only (NOT classify: its default model claude-haiku-4-5 has no
# adaptive thinking). Anthropic → output_config.effort (sonnet-5/opus adaptive
# thinking). OpenAI → reasoning_effort — set ONLY if you switch to a reasoning
# model (o-series/gpt-5); gpt-4.1 is NOT a reasoning model and would reject it.
# DeepSeek has no effort param — pick the model instead (deepseek-chat vs
# deepseek-reasoner) via LLM_MODEL_DEEPSEEK_*.
LLM_ANTHROPIC_EFFORT=low
# LLM_OPENAI_EFFORT=low
# Fine-grained override per (provider,role) — e.g. force effort on classify:
# LLM_EFFORT_ANTHROPIC_TRIAGE=low

# ── M1.8: outbound delivery ──
# SECRET — the WRITE-scoped whatsapp_manager key send() presents (R1/D-G). Resolved
# via the credential store (POST /admin/credentials {"name":"WHATSAPP_MANAGER_WRITE_KEY",
# "value":"..."}) OR this env fallback. If UNSET, send() falls back to the read key
# → a clean 403 (never a silent unauthenticated send). DO NOT commit a value here.
# WHATSAPP_MANAGER_WRITE_KEY=
#
# Kill-switch (NON-secret). The drainer is registered ONLY when EXACTLY "true";
# unset / "false" / anything else → disabled (approved rows sit in the queue). NOTE:
# parsed as a strict string→bool, so the literal string "false" stays false.
OUTBOUND_ENABLED=false
# Drainer tuning (NON-secret; defaults shown).
# OUTBOUND_DRAIN_INTERVAL_MS=5000     # drainer tick cadence
# OUTBOUND_RATE_PER_HOUR=10           # per-recipient hourly send cap
# OUTBOUND_MIN_GAP_MS=5000            # per-recipient minimum inter-send gap
# OUTBOUND_MAX_RECIPIENT_FAILURES=3   # failures in the window → pause that recipient
# OUTBOUND_FAILURE_WINDOW_MIN=60      # failure-breaker + pause window (minutes)
# OUTBOUND_DEFAULT_TZ=America/Panama  # send-window tz for customer-less rows
# OUTBOUND_STUCK_MINUTES=10           # 'sending' older than this → reclaimed (failReview)
# HOLIDAY_COUNTRY=PA                  # date-holidays country for the 'global' seed

# ── M1.9: early-warning alert (NON-secret; default shown) ──
# One admin Telegram notice after this many CONSECUTIVE triage-row failures (a
# dependency is down), instead of only the ~30-min failStuck terminal alert.
# TRIAGE_FAILURE_ALERT_THRESHOLD=3

# ── M2a: knowledge-sync — folder-sourced docs → pgvector RAG (NON-secret) ──
# Kill-switch (mirrors OUTBOUND_ENABLED): the boot-time sync worker is registered ONLY
# when EXACTLY "true"; unset / "false" / anything else → disabled (nothing embeds on
# boot). Flip to true once the corpus customers are onboarded. The embedding credential
# is OPENAI_API_KEY (above); the RAG needs pgvector (the dedicated ao-postgres DB).
KNOWLEDGE_SYNC_ENABLED=false
# KNOWLEDGE_SYNC_INTERVAL_MS=3600000       # corpus re-scan cadence (1h)
# Task-inventory sync (Layer-1 backfill groundwork): mirror each onboarded customer's portal
# tasks (ALL statuses) into agent_memory as memory_type='task', hash-controlled by the SAME
# reconciler (a status/priority change re-embeds). Unlocks "status of X" answers + a content-
# keyed inventory for backfill dedup. Kill-switch, DORMANT by default (mirrors KNOWLEDGE_SYNC).
TASK_INVENTORY_ENABLED=false
# TASK_INVENTORY_SYNC_INTERVAL_MS=1200000   # task re-scan cadence (20m)
# Live-dedup fingerprint seed: mirror OPEN portal tasks into agent_conversation_links (portal
# channel) during the inventory tick so a new WhatsApp/email msg folds into an existing task
# instead of duplicating it. Needs TASK_INVENTORY_ENABLED + CROSS_CHANNEL_DEDUP_ENABLED + OPENAI_API_KEY.
LIVE_DEDUP_FINGERPRINT_ENABLED=true
# Backfill sweep (Layer-2): reconcile historical threads against the task inventory —
# memory-link on match (no portal write), draft task proposal on an unmatched work-request.
# Kill-switch, DORMANT by default; dry-run writes NOTHING. Needs a history reader (attended).
BACKFILL_ENABLED=false
# M3(b) starred-email leg: sweep the founder's STARRED Gmail threads (is:starred ∩ customer identity)
# into the same proposal pipeline. Gated, DORMANT by default; reuses the existing Gmail client.
BACKFILL_STARRED_ENABLED=false
# BACKFILL_STARRED_MAX_THREADS=50           # starred threads pulled per Gmail account (cost guard)
# BACKFILL_MATCH_MAX_DISTANCE=0.5           # cosine ceiling for a task candidate
# BACKFILL_JUDGE_THRESHOLD=0.6              # LLM-judge confirm gate (false link > missed link)
# BACKFILL_MATCH_K=5                        # candidate fan-out
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIM=1536                # MUST equal the vector(N) column in migration 014
# KNOWLEDGE_TOMBSTONE_MAX_RATIO=0.5        # refuse-to-tombstone guard (0..1): skip+WARN if a
                                           # source's vanished-doc ratio exceeds this (IO glitch)

# ── M2a(b): scoped RAG retrieval INTO the triage context (NON-secret) ──
# Kill-switch (mirrors KNOWLEDGE_SYNC_ENABLED): the retriever is injected into triage
# ONLY when EXACTLY "true". Additive + best-effort — a missing OPENAI_API_KEY (above),
# an empty RAG, or a search error degrades to NO injected knowledge, never a triage
# failure. Flip to true once a corpus has been ingested (KNOWLEDGE_SYNC_ENABLED).
KNOWLEDGE_RETRIEVAL_ENABLED=false
# KNOWLEDGE_RETRIEVAL_K_CUSTOMER=5         # top-k nearest chunks from the customer's own rows
# KNOWLEDGE_RETRIEVAL_K_SHARED=3           # top-k nearest chunks from shared (customer_id IS NULL) rows
# KNOWLEDGE_RETRIEVAL_MAX_DISTANCE=0.5     # cosine-distance ceiling (0..2); drop chunks beyond it (lower = stricter)

# ── M2a(c): response drafter — cited DRAFT replies for answerable questions (NON-secret) ──
# Kill-switch (mirrors OUTBOUND_ENABLED / KNOWLEDGE_SYNC_ENABLED): the drafter is
# injected into triage ONLY when EXACTLY "true". DORMANT by default → a
# 'question_existing' intent keeps creating a task (the M1.5b behavior), so nothing
# drafts by surprise. NO draft is EVER auto-sent: an is_draft=true row is un-drainable
# until an explicit founder Approve/Edit; Reject cancels it. All three outcomes land in
# agent_decisions (accepted/modified/rejected).
# DEPENDENCY: the drafter only fires when retrieved knowledge exists → set
# KNOWLEDGE_RETRIEVAL_ENABLED=true too, or enabling this alone stays dormant.
# PRECONDITION (Telegram): the ✏️ Edit-capture reads `message` updates, so the bot's
# group privacy mode MUST be OFF (BotFather /setprivacy) or free-text edits never arrive.
KNOWLEDGE_DRAFT_ENABLED=false

# ── Wave-1 streams (all default-OFF; flip per feature at its live gate) ──────────

# MI "Project Brain": internal-knowledge RAG over OUR planning/decision docs (SEPARATE
# internal_knowledge table, mig 016; structurally isolated from customer replies). The
# stdio MCP server (scripts/mcp-project-brain.ts) works regardless of this flag; the flag
# only controls the hourly in-process re-sync worker. Embed the corpus once with
# `npm run internal:reconcile:once` (needs OPENAI_API_KEY).
KNOWLEDGE_INTERNAL_ENABLED=false
# KNOWLEDGE_INTERNAL_SYNC_INTERVAL_MS=3600000
# KNOWLEDGE_INTERNAL_K=8
# KNOWLEDGE_INTERNAL_MAX_DISTANCE=0.6

# M3(c): feedback learning — embeds a customer-scoped feedback memory on a modified/rejected
# draft, so future similar questions retrieve the correction. Needs OPENAI_API_KEY.
FEEDBACK_LEARNING_ENABLED=false
# FEEDBACK_LEARNING_INTERVAL_MS=300000
# FEEDBACK_LEARNING_BATCH=50

# M3(d): daily acceptance report to the Telegram Admin topic (one post/day, tz-local).
ACCEPTANCE_REPORT_ENABLED=false
# ACCEPTANCE_REPORT_INTERVAL_MS=21600000
# ACCEPTANCE_REPORT_TZ=America/Panama

# M3(e): weekly pattern digest to the Telegram Admin topic (one post/ISO-week, tz-local).
# Clusters the week's corrections + customer themes by their stored embeddings (read-only,
# NO new embed calls) and surfaces the top RECURRING patterns. Requires Telegram.
WEEKLY_PATTERNS_ENABLED=false
# WEEKLY_PATTERNS_INTERVAL_MS=21600000
# WEEKLY_PATTERNS_TZ=America/Panama
# WEEKLY_PATTERNS_WINDOW_DAYS=7
# WEEKLY_PATTERNS_MAX_DISTANCE=0.2
# WEEKLY_PATTERNS_MIN_COUNT=3
# WEEKLY_PATTERNS_TOP_K=5
# WEEKLY_PATTERNS_MAX_SIGNALS=2000

# M5(b): daily founder briefing to the Telegram Admin topic (one post/day, tz-local) —
# counts + oldest-age of pending draft replies + backfill task proposals, and a ranked
# "who needs attention" list. Read-only aggregation over existing queues (no new table).
DAILY_BRIEFING_ENABLED=false
# DAILY_BRIEFING_INTERVAL_MS=21600000
# DAILY_BRIEFING_TZ=America/Panama
# DAILY_BRIEFING_TOP_N=5

# M5(c): Telegram founder slash commands — /pending (queue counts + oldest age), /briefing (the
# daily digest on demand), /help. CORE router reusing the briefing readers (no new query). Reads
# `message` updates (bot group privacy mode must be OFF). Requires Telegram. Dormant by default.
SLASH_COMMANDS_ENABLED=false

# M2(d): channel-correct EMAIL send — approved email drafts reply THREADED from the
# originating account (work/personal isolation). Second kill-switch UNDER OUTBOUND_ENABLED.
OUTBOUND_EMAIL_ENABLED=false

# Correction loop: DRAFT_REVISE 🔁 — reply an instruction to a draft → the agent regenerates it
# and learns the correction (product-fact → shared, else customer-scoped). Grounding cite-or-
# abstain hardening is always-on; this flag only enables the Revise button + instruction capture.
DRAFT_REVISE_ENABLED=true

# Style-Correction Always-On lane: TONE/STYLE/persona corrections ("be warmer", "less formal")
# never clear the embedding distance gate, so they were learned-but-unreachable. When enabled, the
# drafter pulls ALL of a customer's style corrections (kind='style') on EVERY draft — not distance-
# gated — and injects them as persistent voice guidance (directive, never a citation). Only affects
# the drafter when KNOWLEDGE_DRAFT_ENABLED is on. DORMANT by default. STYLE_LANE_MAX caps how many
# directives are injected per draft (newest-first).
STYLE_LANE_ENABLED=false
# STYLE_LANE_MAX=12

# M5(d): Google Calendar READ → upcoming meetings injected into drafts. At draft time the drafter
# pulls the drafted customer's UPCOMING meetings (matched by the sender's email) from the founder's
# calendar and injects them as draft context the reply may acknowledge ("see you Tuesday") — never a
# citation source. Only affects the drafter when KNOWLEDGE_DRAFT_ENABLED is on. READ-ONLY (no event
# creation). Best-effort — a calendar miss never fails a draft. DORMANT by default.
# CREDENTIALS: GOOGLE_CALENDAR_WORK_OAUTH / GOOGLE_CALENDAR_PERSONAL_OAUTH (or legacy single
# GOOGLE_CALENDAR_OAUTH), JSON {client_id,client_secret,refresh_token}, scope calendar.readonly —
# resolved via resolveCredential (SECRETS above), NEVER in the zod schema. Reads whichever accounts
# have a credential present.
CALENDAR_ENABLED=false
# CALENDAR_LOOKAHEAD_DAYS=7
# CALENDAR_MAX_EVENTS=5
# CALENDAR_ID=primary                 # legacy single-account fallback only
# GOOGLE_CALENDAR_WORK_ID=primary
# GOOGLE_CALENDAR_PERSONAL_ID=primary
# CALENDAR_TZ=America/Panama
