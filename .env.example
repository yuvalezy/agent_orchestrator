NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# Database — DATABASE_URL wins when present, otherwise the discrete PG* vars.
# Points at the shared ops-dev `ezy-postgres`, host-published on 42016. Under
# docker `network_mode: host` (ADR-11/BF1) the container uses these SAME
# localhost values — do not switch to ezy-postgres:5432.
PGHOST=localhost
PGPORT=42016
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=agent_orchestrator
# DATABASE_URL=postgres://postgres:postgres@localhost:42016/agent_orchestrator

# ── M1.2: outbound-edge base URLs (NON-secret) ──
# Host-mode defaults; under docker network_mode:host the container uses the same
# localhost values. WA runs on its own compose, portal is a host process.
EZY_PORTAL_BASE_URL=http://localhost:5040
WHATSAPP_MANAGER_BASE_URL=http://localhost:3000

# ── M1.2: Telegram forum ids (NON-secret; the bot TOKEN is a credential below) ──
# Supergroup chat id — the -100XXXXXXXXXX number (from getUpdates / @RawDataBot).
TELEGRAM_SUPERGROUP_CHAT_ID=
# message_thread_id of the pinned "Admin" topic (optional; blank = General topic).
TELEGRAM_ADMIN_TOPIC_ID=

# ── M1.2: SECRETS — resolved via src/config/credentials.ts (env now; M1.4 sealed
#          store later). NEVER add these to the zod schema or channel_instances.config.
# EZY Portal tenant API key (scoped ten_ key). Ref: EZY_PORTAL_API_KEY.
EZY_PORTAL_API_KEY=
# whatsapp_manager read key (x-api-key). Ref: WHATSAPP_MANAGER_API_KEY.
WHATSAPP_MANAGER_API_KEY=
# Telegram bot token from BotFather (12345:AA...). Ref: TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=
